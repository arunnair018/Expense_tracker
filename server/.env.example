# ── Server ─────────────────────────────────────────────────────
PORT=5001

# ── MongoDB Atlas ───────────────────────────────────────────────
# Local:  mongodb://localhost:27017/bank-tally
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bank-tally?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────────────
# Use a long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────
# In production set this to your custom domain (comma-separated if multiple)
# Vercel *.vercel.app URLs are allowed automatically — no need to list them
CLIENT_URL=http://localhost:5173

# ── Optional ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_api_key_here
